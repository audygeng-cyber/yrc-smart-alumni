PORT=4000

# --- ขั้นต่ำให้ API ใช้งานกับฐานข้อมูลจริง ---
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, ADMIN_UPLOAD_KEY
# (ถ้ายังไม่ใส่ — เส้นทางพอร์ทัล GET /api/portal/* จะ fallback เป็นข้อมูลตัวอย่างในโค้ด)

# CORS — คั่นหลาย origin ด้วย comma (ต้องใส่ URL ของ Vercel/โดเมนจริงเมื่อ deploy)
# ค่า Origin ที่เบราว์เซอร์ส่งมักไม่มี slash ท้าย — ใช้ https://โดเมน.vercel.app (ไม่ใช่แบบลงท้ายด้วย /)
# ถ้าไม่ตั้ง ฝั่งโค้ดจะยอมรับ http://localhost:5173 และ http://127.0.0.1:5173 เป็นค่าเริ่มต้น
# FRONTEND_ORIGINS=https://yrc-smart-alumni-frontend.vercel.app,http://localhost:5173
# CORS สำหรับ Vercel: ถ้า FRONTEND_ORIGINS มีโดเมน *.vercel.app อยู่แล้ว API จะยอมรับทุก https://*.vercel.app อัตโนมัติ (preview)
# บังคับปิดการขยายนี้: FRONTEND_CORS_ALLOW_VERCEL=0
# บังคับเปิดแม้ไม่มี vercel ใน list: FRONTEND_CORS_ALLOW_VERCEL=1

# Supabase (ใช้ service role เฉพาะฝั่ง server — ห้ามใส่ใน frontend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# คีย์ง่าย ๆ สำหรับป้องกัน endpoint admin ชั่วคราว (เปลี่ยนเป็นค่ายาวใน production)
ADMIN_UPLOAD_KEY=change-me-in-production

# ประธานรุ่น — อนุมัติขั้นแรก (ถ้าไม่ตั้ง ให้ใช้ x-admin-key แทนได้ชั่วคราว)
# แบบคีย์เดียวทุกรุ่น:
PRESIDENT_UPLOAD_KEY=
# หรือแยกคีย์ตามรุ่น (JSON) — คีย์รุ่นต้องตรงกับ requested_data.batch หลัง normalize
# PRESIDENT_KEYS_JSON={"0507":"secret-รุ่น507","1002":"secret-รุ่น1002"}
# แบบขยาย (ผูกประธานรุ่นในทะเบียน + ซิงก์ด้วย POST /api/admin/members/sync-registry-presidents):
# PRESIDENT_KEYS_JSON={"2520":{"key":"secret-2520","member_id":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"}}
PRESIDENT_KEYS_JSON=

# LINE Login (OAuth 2.1) — Channel ID / Secret จาก LINE Developers → LINE Login channel
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# ไม่บังคับ — ถ้าไม่ตั้ง จะใช้ LINE_CHANNEL_SECRET ลงนาม OAuth state (รองรับล็อกอินบนมือถือคนละ WebView/Safari)
# LINE_OAUTH_STATE_SECRET=

# Callback URL ต้องตรงกับที่ตั้งใน LINE console (คั่นหลายค่าด้วย comma)
# ใน dev ถ้าไม่ตั้ง ฝั่ง API จะใช้ localhost เดียวกับด้านบนอัตโนมัติ (ไม่ใช้ใน NODE_ENV=production)
LINE_REDIRECT_URIS=http://localhost:5173/,http://127.0.0.1:5173/

# Web Push (VAPID) — สร้างคู่คีย์: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
