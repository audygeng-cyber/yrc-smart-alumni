# URL ของ Backend API (Express)
VITE_API_URL=http://localhost:4000
# Production (Vercel): ชี้ Cloud Run เท่านั้น เช่น https://xxxx.run.app — ไม่ลงท้ายด้วย /api

# LINE Login (Channel ID แบบ public — ใส่ใน LINE Developers → Basic settings)
VITE_LINE_CHANNEL_ID=
# Production / `vite build`: ต้องตรงกับ Callback URL ใน LINE และค่า LINE_REDIRECT_URIS ฝั่ง backend (ท้ายมี / หรือไม่มี ให้ตรงทุกที่)
# โหมด dev (`npm run dev`): แอปใช้ origin ปัจจุบัน (เช่น http://localhost:5173/) เป็น callback อัตโนมัติ — แม้ในไฟล์นี้จะยังชี้ Vercel ก็จะไม่ถูกส่งกลับไป production หลังล็อกอิน LINE
VITE_LINE_REDIRECT_URI=http://localhost:5173/
# ตัวอย่าง production (Vercel): VITE_LINE_REDIRECT_URI=https://yrc-smart-alumni-frontend.vercel.app/

# ช่วงเวลาโหลดสแนปช็อตพอร์ทัลสมาชิก/กรรมการ/Academy ซ้ำ (มิลลิวินาที) — ค่าเริ่มต้น 120000 (2 นาที) ขั้นต่ำ 10000; ตั้งเป็น 0 เพื่อปิด polling
# VITE_PORTAL_SNAPSHOT_POLL_MS=120000

# เปิดการกันเส้นทางตามบทบาท (app_user_roles) — เมื่อเปิดต้องมี LINE UID และบันทึกบทบาทใน DB
# VITE_ENFORCE_APP_RBAC=true
